# ============================================
# Polymarket Reward Farming Bot Configuration
# ============================================
# Copy this file to .env and fill in your values

# Your Ethereum private key (hex, without 0x prefix)
# This is used to sign orders and derive API credentials
PRIVATE_KEY=your_private_key_here

# Polymarket CLOB API host
CLOB_API_HOST=https://clob.polymarket.com

# Polymarket Gamma API host (market discovery)
GAMMA_API_HOST=https://gamma-api.polymarket.com

# Chain ID (137 = Polygon mainnet)
CHAIN_ID=137

# CLOB order signing — leave unset for AUTO (recommended on Polygon):
#   Calls Polymarket's Gnosis Safe factory; if a proxy is deployed for your key, uses type 2 + that address.
# Explicit values: EOA (0), POLY_PROXY (1), POLY_GNOSIS_SAFE (2), or AUTO
# POLY_SIGNATURE_TYPE=

# Required only for explicit POLY_PROXY (1) or POLY_GNOSIS_SAFE (2): profile wallet from polymarket.com/settings
# FUNDER_ADDRESS=

# RPC for AUTO detection (balance / code checks). Override if the default is slow or blocked.
# POLYGON_RPC_URL=https://polygon-bor-rpc.publicnode.com

# ============================================
# Strategy Configuration
# ============================================

# Maximum number of markets to farm simultaneously
MAX_MARKETS=5

# Capital to allocate per market (in USDC)
CAPITAL_PER_MARKET=500

# Spread from midpoint (e.g., 0.02 = 2 cents from midpoint)
SPREAD_FROM_MIDPOINT=0.02

# Order size per side (in USDC)
ORDER_SIZE=50

# Minimum reward pool to consider a market (daily, in USDC)
MIN_REWARD_POOL=50

# ============================================
# Risk Management
# ============================================

# Maximum inventory per market (in shares)
MAX_INVENTORY_PER_MARKET=500

# Maximum total portfolio exposure (in USDC)
MAX_TOTAL_EXPOSURE=5000

# Daily loss limit - bot stops if daily P&L drops below this (in USDC)
DAILY_LOSS_LIMIT=-100

# Cooldown after rapid fills (in milliseconds)
FILL_COOLDOWN_MS=5000

# ============================================
# Monitoring (Optional)
# ============================================

# Discord webhook URL for alerts (optional)
DISCORD_WEBHOOK_URL=

# Telegram bot token and chat ID for alerts (optional)
TELEGRAM_BOT_TOKEN=
TELEGRAM_CHAT_ID=

# Enable dry run mode (no real orders, just simulation)
DRY_RUN=false

# Log level: debug, info, warn, error
LOG_LEVEL=info
